# CloudStack API credentials and configuration
CS_ENDPOINT = "cloudstack.example.org:8080/client/api"
CS_KEY = "api key"
CS_SECRET = "secret key"
CS_CONFIG = "src/cloudstack.ini"

# Keycloak
KC_SERVER_URL=https://keycloak.example.org/
KC_REALM=yourrealm
KC_CLIENT_ID=admin-cli
KC_USERNAME=admin
KC_PASSWORD=changeme
KC_VERIFY_TLS=true

# Provisioner
POLL_INTERVAL_SECONDS=5
STATE_PATH=./state.json

# Idempotency flag written back to Keycloak user attributes
KC_PROVISIONED_ATTR=cloudstackProvisioned
KC_ACCOUNT_ATTR=cloudstackAccount